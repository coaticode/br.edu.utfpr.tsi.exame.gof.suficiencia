import br.edu.utfpr.tsi.exame.gof.arestruturais.MeuLogger;
import br.edu.utfpr.tsi.exame.gof.arestruturais.MonitorDesenpenhoDecorator;
import br.edu.utfpr.tsi.exame.gof.comportamentais.ExportJsonStrategy;
import br.edu.utfpr.tsi.exame.gof.comportamentais.ExportTextoStrategy;
import br.edu.utfpr.tsi.exame.gof.comportamentais.ExportadorContexto;
import br.edu.utfpr.tsi.exame.gof.comportamentais.NotificadorServiceObserver;
import br.edu.utfpr.tsi.exame.gof.comportamentais.SecretariaObserver;
import br.edu.utfpr.tsi.exame.gof.comportamentais.SetorTIObserver;
import br.edu.utfpr.tsi.exame.gof.suficiencia.dao.UsuarioDAO;
import br.edu.utfpr.tsi.exame.gof.suficiencia.dao.UsuarioDAOImplements;
import br.edu.utfpr.tsi.exame.gof.suficiencia.model.Usuario;

public class Programa {

	public static void main(String[] args) {
		System.out.println("====================================================");
		System.out.println("SISTEMA DE REGISTRO DE USUARIOS - TSI - UTFPR - TOLEDO");
		System.out.println("EXAME DE SUFICIÊNCIA: PADRÕES GOF");
		System.out.println("SIDNEI B SANTOS - RA ********");
		System.out.println("====================================================\n");

		try {
			// ------------------------------------------------------------
			// CENARIO 1: PADRÃO SINGLETON E FACTORY METHOD
			// ------------------------------------------------------------

			System.out.println(">>> [CENARIO 1] Inicializando Infraestrutura de Dados - Executando Regra de Negócio: Listar Usuarios");
			GerenciadorSingleton gerenciador = GerenciadorSingleton.getInstance();
			
			UsuarioDAOImplements daoSimples = new UsuarioDAOImplements();
			List<Usuario> lista1 = daoSimples.listarTodos();
			//List<Usuario> lista2 = daoSimples.listarTodos();
			
			
			System.out.println("\n--- RESULTADO DA BUSCA ---");
			for (Usuario usuario : lista1) {
				System.out.println("Aluno: " + usuario.getNome() + " | Email: " + usuario.getEmail());
			}
			System.out.println("----------------------------------------------------\n");

			// O Factory Method trabalha internamente no Singleton
			gerenciador.definirTipoBanco("SQL");
			gerenciador.realizarOperacao();
			System.out.println("Configuração concluída com sucesso.\n");

			
			
			// ------------------------------------------------------------
			// CENARIO 2: PADRAO ADAPTER (LOG4J)
			// ------------------------------------------------------------

			System.out.println(">>> [CENARIO 2] Configurando Auditoria de Segurança - PADRÃO ADAPTER");

			MeuLogger logger = new Log4jAdapter();
			logger.registrar("O sistema foi iniciado pelo administrador.");
			System.out.println("Logs de auditoria integrados via Adapter.\n");


			// ------------------------------------------------------------
			// CENARIO 3: OPERAÇAO DECORADA (Monitoramento de Eficiencia)
			// ------------------------------------------------------------
			System.out.println(">>> [CENARIO 3] Aplicando Decorator de Eficiência - DECORATOR");

			// ENVELOPE
			UsuarioDAO daoDecorado = new MonitorDesenpenhoDecorator(daoSimples);

			List<Usuario> lista2 = daoDecorado.listarTodos();

			System.out.println("O Decorator ENVOLVEU a execução e mediu o tempo.");
			System.out.println("----------------------------------------------------\n");

			// ------------------------------------------------------------
			// CENARIO 4: PROVA (PROTECAO DO SINGLETON)
			// ------------------------------------------------------------
			System.out.println(">>> [CENARIO 4] Teste do Singleton 'FORÇANDO' NOSQL - FACTORY");
			System.out.println("Tentando redefinir o banco de dados em tempo de execução...");
			//gerenciador.definirTipoBanco("NOSQL");
			//gerenciador.realizarOperacao();

		} catch (IllegalStateException e) {
			System.err.println("\n[AVISO DE SEGURANÇA] Interrupção controlada pelo Singleton:");
			System.err.println("Motivo: " + e.getMessage());
		} catch (Exception e) {
			System.err.println("\n[ERRO INESPERADO]: " + e.getMessage());
		}

		// ------------------------------------------------------------
		// CENARIO 5: PADRAO STRATEGY MULTIPLAS EXPORTAÇOES
		// ------------------------------------------------------------
		System.out.println("----------------------------------------------------\n");
		System.out.println(">>> [CENARIO 5] Exportação de Relatórios Acadêmicos - STRATEGY");
		UsuarioDAOImplements daoSimples = new UsuarioDAOImplements();
		List<Usuario> lista1 = daoSimples.listarTodos();
		
		ExportadorContexto exportador = new ExportadorContexto();
		System.out.println("\n");
		System.out.println("Escolhendo formato: JSON");
		exportador.setStrategy(new ExportJsonStrategy());
		exportador.executarExportacao(lista1);

		System.out.println("\nTroca dinâmica de formato: TXT");
		
		
		exportador.setStrategy(new ExportTextoStrategy());
		exportador.executarExportacao(lista1);
		
		System.out.println("----------------------------------------------------\n");

		// ------------------------------------------------------------
		// CENARIO 6: PADRÃO OBSERVER (NORIFICAÇAO DE LISTAR USUARIO)
		// ------------------------------------------------------------
		System.out.println(">>> [CENARIO 6] Sistema de Notificações ao listar Usuario");
		
		
		//reutilizando
		UsuarioDAO dao = new MonitorDesenpenhoDecorator(new UsuarioDAOImplements());

		dao.adicionarObservador(new SetorTIObserver());
		dao.adicionarObservador(new SecretariaObserver());

		List<Usuario> usuarios = dao.listarTodos();

		System.out.println("\n====================================================");
		System.out.println(" DEMONSTRAÇÃO FINALIZADA");
		System.out.println("======================================================");
	}
}