package br.edu.utfpr.tsi.exame.gof.suficiencia.dao;

import java.util.ArrayList;
import java.util.List;

import br.edu.utfpr.tsi.exame.gof.suficiencia.model.Usuario;
import br.edu.utfpr.tsi.exame.gof.aqestruturais.Log4jAdapter;
import br.edu.utfpr.tsi.exame.gof.comportamentais.*;
import br.edu.utfpr.tsi.exame.gof.criacionais.GerenciadorSingleton;

public class UsuarioDAOImplements implements UsuarioDAO{
	
	private List<RegistroObserver> observadores = new ArrayList<>();

    @Override
    public void adicionarObservador(RegistroObserver observer) {
        observadores.add(observer);
    }

    @Override
    public void removerObservador(RegistroObserver observer) {
        observadores.remove(observer);
    }
	
	// METODO LISTAR TODOS OS USUARIOS DO BANCO + LOGS
	public List<Usuario> listarTodos() {
        GerenciadorSingleton conexao = GerenciadorSingleton.getInstance();
        conexao.conectar();
        
        //LOGS E OBSERVADORES
        Log4jAdapter log = new Log4jAdapter();
        log.registrar("Iniciando busca de todos os usuarios no sistema.");
        this.notificar("Acesso a base de dados para listagem de usuarios.");
        
        
        System.out.println("Buscando usuarios via: " + conexao.getStatus() + "ID Conexao: " + conexao.getIdConexao());

        try {
        	
        	try {
        	Thread.sleep(1000);
        	
        	} catch (InterruptedException e) {
                e.printStackTrace();
            }
        	
        List<Usuario> usuarios = new ArrayList<>();
        usuarios.add(new Usuario(1, "Fulano de Tal", "fulano@Gmail.com"));
        usuarios.add(new Usuario(2, "Beltrano", "beltrano@Gmail.com"));
        
        
        log.registrar("Busca finalizada com sucesso. Total de registros: " + usuarios.size());
        return usuarios;
    } catch (Exception e) {
        log.registrar("ERRO CRITICO: Falha ao listar usuarios. Detalhe: " + e.getMessage());
        throw e;
    }
    }
	
	//abstracao do Registro Observer
	private void notificar(String mensagem) {
        for (RegistroObserver ob : observadores) {
            ob.atualizar(mensagem);
        }
    }
	
	
	// restantes do crud
}
